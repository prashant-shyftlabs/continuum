# =============================================================================
# ORCHESTRATOR SDK - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values
# Lines starting with # are comments
# Uncomment and set values for the providers you want to use
# =============================================================================


# =============================================================================
# LLM PROVIDER API KEYS
# =============================================================================
# Set API keys for the LLM providers you want to use
# LiteLLM supports 100+ providers - these are the most common ones

# OpenAI (GPT-4, GPT-4o, GPT-3.5)
# OPENAI_API_KEY=your-openai-key
# OPENAI_ORGANIZATION=org-xxx  # Optional: OpenAI organization ID

# Google Gemini / Vertex AI
# GEMINI_API_KEY=your-gemini-key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json  # For Vertex AI
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Azure OpenAI
# AZURE_API_KEY=your-azure-key
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-15-preview

# AWS Bedrock
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION_NAME=us-east-1

# Cohere
# COHERE_API_KEY=your-cohere-key

# Mistral AI
# MISTRAL_API_KEY=your-mistral-key

# Together AI
# TOGETHER_API_KEY=your-together-key
# TOGETHERAI_API_KEY=your-together-key  # Alternative env var

# Groq
# GROQ_API_KEY=your-groq-key

# Fireworks AI
# FIREWORKS_API_KEY=your-fireworks-key

# Perplexity
# PERPLEXITYAI_API_KEY=your-perplexity-key

# Replicate
# REPLICATE_API_KEY=your-replicate-key

# Ollama (local models - no API key needed)
# OLLAMA_HOST=http://localhost:11434

# Hugging Face 
#HUGGINGFACE_API_KEY=<HUGGING_FACE_KEY>

# =============================================================================
# DEFAULT LLM CONFIGURATION
# =============================================================================
# Default model for agent LLM calls
# Format: provider/model or just model name for OpenAI
# Examples:
#   - gpt-4o-mini (OpenAI)
#   - gpt-4o (OpenAI)
#   - gemini/gemini-2.0-flash (Google)
#   - gemini/gemini-1.5-pro (Google)
#   - claude-3-5-sonnet-20241022 (Anthropic)
#   - anthropic/claude-3-opus-20240229 (Anthropic)
#   - azure/gpt-4 (Azure OpenAI)
#   - bedrock/anthropic.claude-3-sonnet (AWS Bedrock)
#   - together_ai/meta-llama/Llama-3-70b-chat-hf (Together AI)
#   - groq/llama3-70b-8192 (Groq)
#   - ollama/llama3 (Local Ollama)

DEFAULT_LLM_MODEL=gemini/gemini-2.5-flash
FALLBACK_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.7 # 0.7, gpt-5 only accepts 1.0
DEFAULT_LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=300
LLM_MAX_RETRIES=3
LLM_ENABLE_FALLBACK=true

# Smart layer (RouterAgent routing_strategy=model_tier). When false, model_tier falls back to llm routing.
SMART_LAYER_ENABLED=true

# Optional: external OpenAI-compatible classifier (e.g. Hugging Face router). Applied by routing playground
# and via orchestrator.agent.config.apply_llm_route_env_overrides(RouterConfig).
# LLM_ROUTE_TIER_CLASSIFIER=light_only
# LLM_ROUTE_TIER_CLASSIFIER=qwen
# HF Qwen classifier (optional overrides — HF_API_KEY alone is enough with tier_classifier=qwen):
# LLM_ROUTE_TIER_CLASSIFIER=qwen
# HF_API_KEY=
# LLM_ROUTE_ROUTER_MODEL=Qwen/Qwen3-4B-Instruct-2507:fastest
# LLM_ROUTE_ROUTER_API_BASE=https://router.huggingface.co/v1
# LLM_ROUTE_ROUTER_API_KEY=
# LLM_ROUTE_FORCE_COMPLETION_MODEL=gpt-4o-mini
# LLM_ROUTE_TIER_CLASSIFIER_HEURISTIC_SHORTCUT=false  # always run classifier LLM (no keyword shortcuts)
#
# Locally hosted classifier (OpenAI-compatible), used when LLM_ROUTE_TIER_CLASSIFIER=qwen_local only.
# Do not use LLM_ROUTE_ROUTER_API_* for local — qwen_local ignores those (avoids calling HF while localhost is down).
# LLM_ROUTE_LOCAL_ROUTER_API_BASE=http://127.0.0.1:8080/v1
# LLM_ROUTE_LOCAL_ROUTER_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit
# LLM_ROUTE_LOCAL_ROUTER_API_KEY=


# =============================================================================
# EMBEDDING PROVIDER CONFIGURATION
# =============================================================================
# Embeddings are used for long-term memory (mem0 + vector store)
# mem0 supports: openai, azure_openai, huggingface, ollama, gemini, vertexai, cohere
# NOTE: mem0 does NOT support "litellm" as embedder - use native providers

# Embedding Provider Options:
#   - openai: text-embedding-3-small (1536), text-embedding-3-large (3072), text-embedding-ada-002 (1536)
#   - huggingface: BAAI/bge-m3 (1024), BAAI/bge-small-en-v1.5 (384), sentence-transformers/* 
#   - cohere: embed-english-v3.0 (1024), embed-multilingual-v3.0 (1024)
#   - ollama: nomic-embed-text (768), mxbai-embed-large (1024), all-minilm (384)
#   - gemini: models/embedding-001 (768)
#   - azure_openai: your-deployment-name
#   - vertexai: text-embedding-004 (768)

EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536
# Embedding API Keys (set for your chosen provider)
# Falls back to LLM provider keys if not set
# EMBEDDER_API_KEY=  # Explicit key for embedder
# EMBEDDER_API_BASE=  # Custom API base URL


# =============================================================================
# MEMORY CONFIGURATION (mem0 + pluggable vector store)
# =============================================================================
# Long-term memory for personalization and context retention

MEMORY_ENABLED=true

# Vector Store Provider: "qdrant" or "milvus"
VECTOR_STORE_PROVIDER=milvus

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=  # For Qdrant Cloud
QDRANT_COLLECTION=orchestrator_memories_openai

# --- Milvus ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=  # For Zilliz Cloud only
MILVUS_COLLECTION=orchestrator_memories

# Memory LLM (for fact extraction - use cheap/fast model)
MEMORY_LLM_MODEL=gemini/gemini-2.5-flash
MEMORY_LLM_TEMPERATURE=0.1

# Memory Isolation Mode
# Set memory isolation mode (for testing mode switching)
# Options: shared, user, agent, run
# Currently testing with "user" mode
MEMORY_ISOLATION=user
# Options: shared (all users), user (per user), agent (per agent), run (per session)
MEMORY_SEARCH_LIMIT=5
MEMORY_HISTORY_DB_PATH=~/.orchestrator/memory_history.db


# =============================================================================
# SESSION CONFIGURATION (Redis)
# =============================================================================
# Short-term conversation memory and session state

SESSION_ENABLED=true
SESSION_REDIS_HOST=localhost
SESSION_REDIS_PORT=6380
SESSION_REDIS_PASSWORD=<PASSWORD>
SESSION_REDIS_DB=0
SESSION_REDIS_SSL=false
SESSION_TTL_SECONDS=172800
SESSION_MAX_MESSAGES=1000
SESSION_KEY_PREFIX=orchestrator:session


# =============================================================================
# LANGFUSE OBSERVABILITY
# =============================================================================
# Tracing, monitoring, and analytics

LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY='your-langfuse-secret-key'
LANGFUSE_PUBLIC_KEY='your-langfuse-public-key'
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_BASE_URL=http://localhost:3000

NEXTAUTH_SECRET=your-nextauth-secret-here

# Tracing Configuration
LANGFUSE_SAMPLE_RATE=1.0
# 1.0 = trace everything, 0.5 = 50% sampling
LANGFUSE_FLUSH_INTERVAL=1
LANGFUSE_FLUSH_AT=15
LANGFUSE_DEBUG=false
# LANGFUSE_RELEASE=v1.0.0  # Optional version tag


# =============================================================================
# LITELLM CONFIGURATION
# =============================================================================
# Advanced LiteLLM settings

LITELLM_VERBOSE=false
# LITELLM_CONFIG_PATH=./litellm_config.yaml  # Custom config file


# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

ENVIRONMENT=development
# Options: development, staging, production

LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL


# =============================================================================
# OPTIONAL: TOKENIZERS WARNING FIX
# =============================================================================
# Suppress HuggingFace tokenizers parallelism warning
TOKENIZERS_PARALLELISM=false

# =============================================================================
# REDIS CONNECTION POOL (NEW)
# =============================================================================
# Maximum connections in Redis pool (default: 10)
# SESSION_REDIS_MAX_CONNECTIONS=10

# =============================================================================
# PARALLEL TOOL EXECUTION
# =============================================================================
# Maximum concurrent tool calls (default: 5)
# MAX_PARALLEL_TOOLS=5


# =============================================================================
# HOSTED UI WIDGET URL 
# =============================================================================
HOSTED_WIDGET_URL=https://app.omnity.shyftops.io
# Disable mem0 telemetry
MEM0_TELEMETRY=false
ANONYMIZED_TELEMETRY=false


# =============================================================================
# Lifecycle Configuration (Shutdown Behavior)
# =============================================================================
# If True, Redis/Langfuse are shared services that persist after shutdown
# When True: Only flush Langfuse traces, don't shutdown client. Don't close Redis connections.
# When False: Fully shutdown Langfuse and close Redis connections on shutdown.
# =============================================================================
SHARED_SERVICES_ENABLED=True

# =============================================================================
# TEMPORAL WORKFLOW ENGINE (Optional)
# =============================================================================
# Durable workflow orchestration with human-in-the-loop approvals
# Requires: pip install -e ".[temporal]"
# Infrastructure: docker compose up -d temporal postgres-temporal temporal-ui

TEMPORAL_ENABLED=true
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=orchestrator-agents
TEMPORAL_ENABLE_HUMAN_IN_LOOP=true
TEMPORAL_APPROVAL_TIMEOUT_SECONDS=86400
TEMPORAL_WORKFLOW_EXECUTION_TIMEOUT=604800
TEMPORAL_ACTIVITY_START_TO_CLOSE_TIMEOUT=300
TEMPORAL_ACTIVITY_RETRY_MAX_ATTEMPTS=3

# =============================================================================
# GATEWAY - SMART LAYER
# =============================================================================
SMART_GATEWAY_URL=https://continuum.shyftops.io/v1
SMART_GATEWAY_API_KEY=your-smart-gateway-api-key
